  {
    "_id": "2359c8af-d920-417e-879b-841011d59648",
    "companyName": "Ministry of the Interior and Kingdom Relations\t",
    "contractName": "The NextGen",
    "description": [
      {
        "_key": "89cd8d795666",
        "_type": "block",
        "children": [
          {
            "_key": "0d806f05714c",
            "_type": "span",
            "marks": [],
            "text": "I built a new search engine for the Ministry of the Interior and Kingdom Relations. It wasn't a large application, but the real challenge was in optimising its speed and performance, making every millisecond count for the end user."
          }
        ],
        "markDefs": [],
        "style": "normal"
      }
