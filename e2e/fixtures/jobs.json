[
  {
    "_id": "69c3c72f-f928-412e-9129-7ca3fc17b20d",
    "companyName": "Royal Netherlands Meteorological Institute",
    "contractName": "The NextGen",
    "description": [
      {
        "_key": "b5c185f0051c",
        "_type": "block",
        "children": [
          {
            "_key": "feefe01bb9ff",
            "_type": "span",
            "marks": [],
            "text": "When I joined KNMI, the team had an existing open-source mapping application called "
          },
          {
            "_key": "dbbb859b5b9b",
            "_type": "span",
            "marks": ["e7f823afba1d"],
            "text": "GeoWeb"
          },
          {
            "_key": "11c1a20f5d0e",
            "_type": "span",
            "marks": [],
            "text": ", but it was struggling with scalability issues and had no test coverage. Scrum had just been introduced and the team was still finding its rhythm. Together with meteorological institutes in Finland and Norway, we had to decide whether to rebuild from scratch or improve what existed. Drawing from past experience, we chose to evolve the existing codebase."
          }
        ],
        "markDefs": [
          {
            "_key": "e7f823afba1d",
            "_type": "link",
            "href": "/projects/opengeoweb"
          }
        ],
        "style": "normal"
      },
      {
        "_key": "dff02e6a9c51",
        "_type": "block",
        "children": [
          {
            "_key": "f6f768621c0d",
            "_type": "span",
            "marks": [],
            "text": "I introduced "
          },
          {
            "_key": "9621b0784229",
            "_type": "span",
            "marks": ["0568a65e6e19"],
            "text": "TypeScript"
          },
          {
            "_key": "15094fa4ddca",
            "_type": "span",
            "marks": [],
            "text": " and "
          },
          {
            "_key": "7ada2501ab02",
            "_type": "span",
            "marks": ["bb676bf75fee"],
            "text": "unit testing with Jest"
          },
          {
            "_key": "7306a13666cf",
            "_type": "span",
            "marks": [],
            "text": " to make refactoring safer, and we reused and refined existing code so the project could keep moving without delays. This approach delivered quick results while gradually raising the quality of the application. Over time, GeoWeb grew into a mature platform with more than 10 modules, became an essential tool in the weather room, and the team continued to expand."
          }
        ],
        "markDefs": [
          {
            "_key": "0568a65e6e19",
            "_type": "link",
            "href": "/tags/typescript"
          },
          {
            "_key": "bb676bf75fee",
            "_type": "link",
            "href": "/tags/jest"
          }
        ],
        "style": "normal"
      }
    ],
