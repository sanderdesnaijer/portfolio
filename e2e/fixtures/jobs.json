        "_type": "block",
        "children": [
          {
            "_key": "d5b645c3236e",
            "_type": "span",
            "marks": [],
            "text": "A short project via Label A and HintTech where I developed an energy calculator widget for Essent, letting users estimate their energy usage and costs."
          }
        ],
        "markDefs": [],
        "style": "normal"
      }
    ],
    "employmentType": "contract",
    "endDate": "2013-01-31T09:17:00.000Z",
